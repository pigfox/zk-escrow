# Copy this file to ../.env (ONE DIRECTORY ABOVE this repo) and populate it.
#
# The real .env lives OUTSIDE the repository on purpose, so secrets can never be
# committed. Load it with:
#
#   set -a; source ../.env; set +a
#
# Nothing in this repo's build, test, or CI path requires these values.
# They are only needed to deploy and to run the AI arbiter agent.

# Base Sepolia address corresponding to PRIVATE_KEY (the deployer / arbiter).
ADDRESS=

# Private key for that address. TESTNET ONLY. Fund with gas dust only.
PRIVATE_KEY=

# Which model backend the arbiter reasons with: "anthropic" (default) or
# "openai". Only the selected provider's key is required — the agent refuses to
# start if it is empty, rather than discovering the problem on the first
# dispute. Leave blank for the Claude default.
AI_PROVIDER=

# Anthropic API key used by the Go arbiter agent to call the Claude API.
# Required when AI_PROVIDER is "anthropic" (or unset).
ANTHROPIC_API_KEY=

# OpenAI API key, used instead of the above when AI_PROVIDER=openai.
OPENAI_API_KEY=

# The deployed EscrowUpgradeable proxy the demos and the agent talk to.
# Printed by ./scripts/deploy.sh.
ESCROW_ADDRESS=

# How many blocks behind head the agent starts scanning on a cold start.
# Optional; defaults to 5000, which at Base Sepolia's ~2s blocks is about three
# hours. Raise it to catch up on disputes older than that.
START_BLOCK_LOOKBACK=
