# Copy this file to ../.env (ONE DIRECTORY ABOVE this repo) and populate it.
#
# The real .env lives OUTSIDE the repository on purpose, so secrets can never be
# committed. Load it with:
#
#   set -a; source ../.env; set +a
#
# Nothing in this repo's build, test, or CI path requires these values.
# They are only needed to deploy and to run the AI arbiter agent.

# Base Sepolia address corresponding to PRIVATE_KEY (the deployer / arbiter).
ADDRESS=

# Private key for that address. TESTNET ONLY. Fund with gas dust only.
PRIVATE_KEY=

# Anthropic API key used by the Go arbiter agent to call the Claude API.
ANTHROPIC_API_KEY=
